# Copy this file to ".env" in the backend/ directory and adjust values as needed.
# Do not commit the real ".env" file.

APP_NAME=MindCraft AI
ENVIRONMENT=development

# Must match the origin the frontend is served from.
# Default matches: python -m http.server 5500 --directory frontend
FRONTEND_ORIGIN=http://127.0.0.1:5500

# Gemini API settings are intentionally not included here yet.
# They will be added when Gemini integration begins, per PROJECT_CONTEXT.md.
