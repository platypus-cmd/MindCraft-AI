# Copy this file to ".env" in the backend/ directory and adjust values as needed.
# Do not commit the real ".env" file.

APP_NAME=MindCraft AI
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins.
# Default covers standard local dev ports. Add production URLs here.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:8080,http://localhost:8080

# Gemini API settings.
# Get an API key from Google AI Studio and paste it only into your local .env.
# Never commit a real API key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=60
